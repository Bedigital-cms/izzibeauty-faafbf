# Media: site /media/<filename> proxies to the CMS public media endpoint, scoped to this tenant.
# Local dev: CMS on :3000. Production: the real CMS origin (or an R2 CDN base + MEDIA_STORAGE=r2 on the CMS).
MEDIA_PUBLIC_BASE=https://app.bedigital.ai/media
MEDIA_TENANT_SLUG=izzibeauty

# Forms: where <Form> POSTs submissions (the CMS origin). Empty = same-origin (404 in dev).
NEXT_PUBLIC_FORMS_ENDPOINT=https://app.bedigital.ai
